extends ../main/base

block append head
  link(rel='stylesheet', href='/css/user.css')
  link(rel='stylesheet', href='/css/profileMediaQueries.css')

block content
  section.sect-mid-contentContainer
    h1.user-heading-h1 USER SETTINGS
    .basic-details
      section.identification
        if userData.photo === undefined
          img.sect-mid-logo-img(src=`/imgs/users/${userId}/user-display-picture/${userData.photo}`)
        else
          img.sect-mid-logo-img(src=`/imgs/default-user-photo.jpg`)
        .full_user_name
          .firstname
            h2 First Name
            - let userFirstName;
            if user.name.firstName === undefined ? userFirstName = 'Enter Your First Name' : userFirstName = user.name.firstName
            input(placeholder=`${userFirstName}`, type='text')
          .secondname
            h2 Second Name
            - let userSecondName;
            if user.name.secondName === undefined ? userSecondName = 'Enter Your First Name' : userSecondName = user.name.secondName
            input(placeholder=`${userSecondName}`, type='text')
          .username
            h2 Username
            - let userName;
            if user.username === undefined ? userName = 'Enter Your First Name' : userName = user.username
            input(placeholder=`${userName}`, type='text')
      section.electronic-address
        h2.eAddress-heading-h1 ELECTRONIC ADDRESS
        .email_phNumber
          .email
            h2 Email
            input(placeholder='Type your email here', type='text')
          .phoneNumber
            h2 Phone Number
            input(placeholder='Type your phone number here', type='text')
        .changePassword
          .old_password
            h2 Old Password
            input(placeholder='Type your old password here', type='text')
          .confirm_password
            h2 Confirm Password
            input(placeholder='Type your old password here', type='text')
          .new_password
            h2 New Password
            input(placeholder='Type your old password here', type='text')
          button.submit_password_info Submit
    .other-userInfo
      .channel_info
        h3 CHANNEL ASSOCIATED
        if channel
          img.sect-mid-logo-img(src=`/imgs/users/${userId}/display-images/${channel.displayImage}`)
        else
          img.sect-mid-logo-img(src=`/imgs/default-user-photo.jpg`)
        a(href=`/user-channel`) 
          .ch_details
            if channel
              h4.ch_details_chUsername= `'@' ${channel.channelUserName}`
              h4.ch_details_chname= channel.name
              button S
            else
              h4.ch_details_chUsername
              h4.ch_details_chname No Channel Found
              button S
      .token_info
        h2 TOKENS
        a(href="/tokens") 
          button GET TOKEN
      .lock_screen
        h2 LOCK
        a(href="/lock")
          button GOTO
    .platform-mode
      h2 PLATFORM MODE
      button.mode_simple Simple
      button.mode_advance Advance
      button.mode_professional Professional
      button.mode_enterprise Enterprise
    .lang_theme
      .language-details
        h2 LANGUAGE
        button SELECT LANGUAGE
      .themes-details
        h2 THEMES
        button GOTO
    button.logoutBtn Logout
    
  script(src='https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.2/axios.min.js')
  script(src="/js/logout.js")
