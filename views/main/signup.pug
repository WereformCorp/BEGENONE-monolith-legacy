doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    link(rel='icon', type='image/x-icon', href='/imgs/Begenuine FavIcon.png')
    link(rel="stylesheet", href="/css/signup.css")
    
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin='')
    link(href='https://fonts.googleapis.com/css2?family=Lexend+Deca:wght@100;200;300;400;500;600;700;800;900&family=Lexend+Exa:wght@100;200;300;400;500;600;700;800;900&family=Lexend+Giga:wght@100;200;300;400;500;600;700;800;900&family=Lexend+Mega:wght@100;200;300;400;500;600;700;800;900&family=Lexend+Peta:wght@100;200;300;400;500;600;700;800;900&family=Lexend+Tera:wght@100;200;300;400;500;600;700;800;900&family=Lexend+Zetta:wght@100;200;300;400;500;600;700;800;900&family=Lexend:wght@100;200;300;400;500;600;700;800;900&family=Montserrat:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap', rel='stylesheet')
    title #{title}


  body
    .container
      .headings
        h1.login-heading BeGenuine
        h3.login-subHeading
          | Welcome To The Light
          br
          span.subheading-note (Btw, Don&apos;t worry about the theme, you can change it later)
      form.login-form
        .firstname
          h3.login-firstname
            | First Name
            span.star *
          input.login-firstname-input(type='text', name='', id='', placeholder='Enter your first name')
        .lastname
          h3.login-lastname
            | Last Name
            span.star *
          input.login-lastname-input(type='text', name='', id='', placeholder='Enter your last name')
        .email
          h3.login-email
            | Email
            span.star *
          input.login-email-input(type='text', name='', id='', placeholder='Enter your email')
        .password
          h3.login-password
            | Password
            span.star *
          input.login-password-input(type='text', name='', id='', placeholder='Enter your password')
        .password-confirm
          h3.login-password-confirm
            | Password Confirm
            span.star *
          input.login-password-confirm-input(type='text', name='', id='', placeholder='Enter your password confirm')
        button.submit-form-btn SUBMIT