extends ../base

block append head
  link(rel='stylesheet', href='/css/clipZ.css')

block content
  section.sect-mid-contentContainer
    input.videoId(type="hidden", value=`${videoIdForComment}`)
    input.userId(type="hidden", value=`${userData ? userData._id : null}`)
    .content-containers.content-container-1(data-video-id=`${video._id}`)
      section.sect-ctntDtls-vdoContainer
        video.sect-mid-vdoPlayer-video.myVideo(id=`video-${video._id}` autoplay loop muted)
          source(src=`${video.cloudFrontUrl}`, type='video/mp4')
        h4.sect-ctntDtls-vdoTitle-overlay= video.title
      .section-column-2
        h4.sect-ctntDtls-vdoTitle= video.title
        section.sect-ctntDtls-head
          .sect-ctntDtls-channelDetails
            - const channelLogoDefault = `https://begenone-images.s3.amazonaws.com/default-user-photo.jpg`
            input(type="hidden", value=`${video.channel ? channelLogo : null}`).channelLogo-url
            img.sect-ctntDtls-chImage(src=`${video.channel ? channelLogo : channelLogoDefault }`, height='30px')
            .sect-ctntDtls-chName_N_subCount
              h4.sect-ctntDtls-chName= video.channel.name
              h4.sect-ctntDtls-subCount
                span= video.channel.subscribersCount
                |  Subscribers
          button.sect-ctntDtls-subsBtn Subscribe
        section.sect-ctntNav-n-mover
          section.section-ctnt-nav.sect-mid-vdoP-nav
            .sect-mid-vdoP-items.sect-mid-vdoP-navLike
              .vdoPlayer-icon-imgs.vdoP-likeIcon.icon.icon-thumbs-up-solid
                i.fa-solid.fa-thumbs-up
              h4.likesCount= `Like - ${video.likes || '0'}`
            .sect-mid-vdoP-items.sect-mid-vdoP-navDislike
              .vdoPlayer-icon-imgs.vdoP-dislikeIcon.icon.icon-thumbs-down-solid
                i.fa-solid.fa-thumbs-down
              h4.dislikesCount= `Dislike - ${video.dislikes || '0'}`
            .sect-mid-vdoP-items.sect-mid-vdoP-navComment
              .vdoPlayer-icon-imgs.vdoP-commentIcon.icon.icon-comment-solid
                i.fa-solid.fa-comment
              h4.vidCommentText= `Comments`
            .sect-mid-vdoP-items.sect-mid-vdoP-navShare
              .vdoPlayer-icon-imgs.vdoP-shareIcon.icon.icon-share-nodes-solid
                i.fa-solid.fa-share
              h4.vidShareText= `Share`
          section.section-ctnt-mover
            .icon-clipz.icon-up-solid.sect-ctntMover-up
              i.fa-solid.fa-circle-up
            .icon-clipz.icon-down-solid.sect-ctntMover-dwn
              i.fa-solid.fa-circle-down
      
      section.ctnt-comments
        section.ctnt-cmmnt-analytics
          h4.ctnt-cmmnt-count
            span.ctnt-cmmnts-text Comments:
            span.ctnt-cmmnts-amount= video.comments.length
          i.fa-solid.fa-xmark
        section.ctnt-cmmnt-inputbox
          form#commentForm.ctnt-cmmnt-inputField
            textarea#commentInput(type='text', placeholder='Type your comment...')
            button#commentBtn(type='submit')
              i.fa-solid.fa-paper-plane
        section.ctnt-cmmnt-list
          each comment in comments
            .ctnt-cmmnt-listItems.ctnt-cmmnt-listItem-1
              .ctnt-cmmnt-accDtls_N_opts
                if comment
                  if comment.channel && comment.channel.displayImage
                    input.hidden-channel-id(type="hidden", value=`${comment.channel._id}`)
                    input.hidden-channel-name(type="hidden", value=`${comment.channel.name}`)
                    img.ctnt-cmmnt-logo(src=`/imgs/users/${comment.channel.displayImage}`)
                  else
                    img.ctnt-cmmnt-logo(src="https://begenone-images.s3.amazonaws.com/default-user-photo.jpg")
                  .ctnt-cmmnt-accDetails
                    - const userOrChannelName = comment.channel ? comment.channel.name : `${firstName + ' ' + secondName}`
                    h4.cmmnt-accDtls= userOrChannelName
                    - const commentDate = new Date(comment.time)
                    h6.cmmnt-date= commentDate.toLocaleString('en-uk', {day: 'numeric', month: 'long', year: 'numeric'})
                  input(type="hidden" value=`${comment._id}`).delete-comment-id
                  - const userIdString = userData._id ? userData._id.toString().trim() : '';
                  - const commentUserIdString = comment.user.toString();
                  - console.log(`userIdString: ${userIdString}, commentUserIdString: ${commentUserIdString}`);
                  if userIdString === commentUserIdString
                    button.delete-comment-btn(data-owner-id=`${commentUserIdString}`) Delete Comment
                  //- .cmmnt-fltrs
                    .cmmnt-fltr-like.vdoPlayer-icon-imgs.vdoP-likeIcon.icon.icon-thumbs-up-solid
                    .cmmnt-fltr-dislike.vdoPlayer-icon-imgs.vdoP-dislikeIcon.icon.icon-thumbs-down-solid
                    .cmmnt-fltr-bkmark.vdoPlayer-icon-imgs.vdoP-bookmarkIcon.icon.icon-bookmark-regular
                    .cmmnt-fltr-menu.vdoPlayer-icon-imgs.vdoP-optsIcon.icon.icon-menu.icon.icon-more-vertical
              h4.ctnt-cmmnt-textCmmnt= comment.comment
              button.ctnt-cmmnt-reply Reply
            //- Modal for confirmation
            div.delete-modal.modal
              div.modal-content
                span.close-modal-btn &times;
                p Are you sure you want to delete this comment?
                button.confirm-delete-btn Yes, Delete
                button.cancel-delete-btn Cancel
  script(src="/js/videoPlayer.js")
  script(src="/js/engagement-video.js")
  script(src="/js/comment.js")
  script(src="/js/deleteComment.js")
  script(src='https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.2/axios.min.js')
  script.
    // Function to toggle comments visibility for a specific video
    const toggleCommentsVisibility = (videoContainer) => {
      const ctntComments = videoContainer.querySelector('.ctnt-comments');

      if (ctntComments.style.display !== 'flex') {
        ctntComments.style.display = 'flex';
        ctntComments.style.opacity = '0';
        ctntComments.style.transform = 'translateX(20px)';
        setTimeout(() => {
          ctntComments.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          ctntComments.style.opacity = '1';
          ctntComments.style.transform = 'translateX(0)';
        }, 10);
      } else {
        ctntComments.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        ctntComments.style.opacity = '0';
        ctntComments.style.transform = 'translateX(20px)';
        setTimeout(() => {
          ctntComments.style.display = 'none';
        }, 500);
      }
    };

    // Function to observe comment button clicks and close buttons for all videos
    const observeCommentButtons = () => {
      // Event delegation: Add a single event listener to a parent element (document)
      document.addEventListener('click', (event) => {
        // Check if the comment button is clicked
        const commentBtn = event.target.closest('.sect-mid-vdoP-navComment');
        if (commentBtn) {
          // Find the specific video container for the clicked button
          const videoContainer = commentBtn.closest('.content-containers');
          toggleCommentsVisibility(videoContainer);
        }

        // Check if the close (x) button is clicked
        const closeBtn = event.target.closest('.fa-xmark');
        if (closeBtn) {
          // Find the specific video container for the clicked button
          const videoContainer = closeBtn.closest('.content-containers');
          const ctntComments = videoContainer.querySelector('.ctnt-comments');
          if (ctntComments) {
            ctntComments.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            ctntComments.style.opacity = '0';
            ctntComments.style.transform = 'translateX(20px)';
            setTimeout(() => {
              ctntComments.style.display = 'none';
            }, 500);
          }
        }
      });
    };

    // Initialize the observer
    observeCommentButtons();

