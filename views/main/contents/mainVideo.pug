extends ../base

block append head
  link(rel='stylesheet', href='/css/mainVideo.css')
  link(rel='stylesheet', href='/css/videoCard.css')
  link(rel='stylesheet', href='/css/mainVideoMediaQueries.css')
  link(rel='stylesheet', href='https://cdn.plyr.io/3.7.8/plyr.css')

block content
  section.sect-mid-contentContainer
    section.sect-mid-videoPlayer
      section.sect-mid-vdoP-c1
        section.sect-mid-vdoP-dtls
          if user && user.channel && user.channel.displayImage
            a(href=`/channels/${video.channel._id}`)
              img.sect-mid-vdoP-chLogo(src=`/imgs/users/${video.channel.user._id}/display-images/${video.channel.displayImage}`)
          else
            img.chList-chnl-img(src="/imgs/default-user-photo.jpg")
          .sect-mid-vdoP-name_N_subCount
            a(href=`/channels/${video.channel._id}`)
              h4.vdoP-name= video.channel.name
              h5.vdoP-subsCount
                span= video.channel.subscribers.length
                |  Subscribers
            div.sect-mid-vdo-meta
              h2.sect-mid-vdo-time= videoTimeAgo
              h2.sect-mid-vdo-views= `| ${video.views} Views`
          .sect-mid-vdo_subscribe
            if areChannelSame
              button(class=`sect-mid-vdoP-subsBtn--analytics`) Analytics
            else
              button(class=`${btnClass}`)= btnText
              - console.log(`${btnClass}`, `${btnText}`)
              input.userId-input(type="hidden", value=`${user._id}`)
              input.videoId-input(type="hidden", value=`${video._id}`)
              input.isUserSubscribed-input(type="hidden", value=`${isUserSubscribed}`)
            //- .sect-mid-vdoP-notify
              svg.sect-mid-vdoP-notify-icon.sect-rgt-icons-imgs.sect-rgt-icon-img-5.icon.icon-bell-solid
