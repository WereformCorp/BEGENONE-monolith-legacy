        section.vdoPlayer-controls
          //- video.sect-mid-vdoPlayer-video(controls)
          //-   source(src=`/video/sample-video.mp4`, type='video/mp4')
          //- THE NEW VIDEO PLAYER
          input.videoId(type="hidden", value=`${videoIdForComment}`)
          video.sect-mid-vdoPlayer-video(controls='', crossorigin='', playsinline='', poster='')
              source(src=`/video/${video.video}`, type='video/mp4', size='576' width='100%')
              | &#x9;&#x9;&#x9;
              source(src=`/video/${video.video}`, type='video/mp4', size='720')
              | &#x9;&#x9;&#x9;
              source(src=`/video/${video.video}`, type='video/mp4', size='1080')
              | &#x9;&#x9;&#x9;
              source(src=`/video/${video.video}`, type='video/mp4', size='1440')
              // Caption files
              track(kind='captions', label='English', srclang='en', src=`/video/${video.video}`, default='')
              | &#x9;&#x9;&#x9;
              track(kind='captions', label='Français', srclang='fr', src=`/video/${video.video}`)
              // Fallback for browsers that don't support the <video> element
              a(href=`/video/${video.video}`, download='') Download

