extends ../base

block append head
  link(rel='stylesheet', href='/css/search.css')
  link(rel='stylesheet', href='/css/mediaQueries.css')

block content
  section.sect-mid-searchContentContainer
    section.sectMid-content
      //- section.sectMid-resultSorts
        .sortBtn-container
          h5.sortBtn-text Sortings
        .keywords-container
          .keywords.keyword-1 Keyword 1
          .keywords.keyword-2 Keyword 2
          .keywords.keyword-3 Keyword 3
          .keywords.keyword-4 Keyword 4
        .content-types-container
          .contents-types.content-type-1 Promotions
          .contents-types.content-type-2 Suggestions
          .contents-types.content-type-3 Top-Notched
      
      section.sectMid-resultContent
        each video in videos
          a(href=`/watch/${video._id}`) 
            .resultContent-box.resultContent-box-1
              .thumb_N_date_views
                if video && video.thumbnailUrl
                  img.thumbnail-img(src=`${video.thumbnailUrl}`)
                else
                  img.thumbnail-img(src=`/imgs/thumbnails/sample.jpg`)
                .date_N_views
                  h4
                    span= video.views
                    |  Views
                  h4
                    span= videoTimeAgo
              .title_N_description
                h2.content-title= video.title
                p.content-description= video.description || `There is no description available.`
                .channel_details
                  //- img.channel-logo(src=`/imgs/users/${video.channel.displayImage}`)
                  if user && user.channel && user.channel.displayImage
                    img.channel-logo(src=`/imgs/users/${video.channel.user._id}/display-images/${video.channel.displayImage}`)
                  else
                    img.channel-logo(src=`https://begenone-images.s3.amazonaws.com/default-user-photo.jpg`)
                  h4.channel-name= `@${video.channel.channelUserName}`
              .date_N_views-2
                  h4
                    span= video.views
                    |  Views
                  h4
                    span= videoTimeAgo

