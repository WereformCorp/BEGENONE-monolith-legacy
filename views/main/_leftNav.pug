  section#sect-2.section-left
    a(href="/") 
      //- h2 BeGenuine
      img.sect-lft-up.bjenuine-text-header(src="https://wereform-imgs.s3.amazonaws.com/begenone-white-transparent-logo.svg", height='40px')
    .sect-lft-dwn
      //- a(href="/lock")
      .sect-lft-dwn-links.sect-lft-dwn-link-1
        img.srd-link-Icons.srd-link-lockIcon.icon.icon-lock-solid(src="https://begenone-images.s3.amazonaws.com/lock-solid.svg", alt="")
        h3.srd-link-texts.srd-link-lockText Lock Screen
      //- a(href="/clipZ/watch/") 
      .sect-lft-dwn-links.sect-lft-dwn-link-2
        img.srd-link-Icons.srd-link-movieIcon.icon.icon-clapperboard-solid(src="https://begenone-images.s3.amazonaws.com/clapperboard-solid.svg", alt="")
        h3.srd-link-texts.srd-link-clipZ ClipZ
      .sect-lft-dwn-links.sect-lft-dwn-link-3
        img.srd-link-Icons.srd-link-playlistIconicon.icon.icon-list-solid(src="https://begenone-images.s3.amazonaws.com/list-ul-solid.svg", alt="")
        h3.srd-link-texts.srd-link-playlistText Playlist
      a(href="/channels") 
        .sect-lft-dwn-links.sect-lft-dwn-link-4
          img.srd-link-Icons.srd-link-subsIcon.icon.icon-channel-icon(src="https://begenone-images.s3.amazonaws.com/user-group-solid.svg", alt="")
