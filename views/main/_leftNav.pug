      .sect-lft-dwn-links.sect-lft-dwn-link-6
        img.srd-link-Icons.srd-link-gemsIcon.icon.icon-gem-solid(src="https://begenone-images.s3.amazonaws.com/gem-solid.svg", alt="")
        h3.srd-link-texts.srd-link-gemsText Gems
      .sect-lft-dwn-links.sect-lft-dwn-link-7
