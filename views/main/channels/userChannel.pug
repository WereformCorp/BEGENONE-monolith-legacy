            svg.ctnt-nav-items-icon.ctnt-nav-item-about.icon.icon-circle-info-solid
              use(xlink:href='#icon-circle-info-solid')
                symbol#icon-circle-info-solid(viewBox='0 0 32 32')
                  path(d='M16 32c8.837 0 16-7.163 16-16s-7.163-16-16-16v0c-8.837 0-16 7.163-16 16s7.163 16 16 16v0zM13.5 21h1.5v-4h-1.5c-0.831 0-1.5-0.669-1.5-1.5s0.669-1.5 1.5-1.5h3c0.831 0 1.5 0.669 1.5 1.5v5.5h0.5c0.831 0 1.5 0.669 1.5 1.5s-0.669 1.5-1.5 1.5h-5c-0.831 0-1.5-0.669-1.5-1.5s0.669-1.5 1.5-1.5zM16 8c1.105 0 2 0.895 2 2s-0.895 2-2 2v0c-1.105 0-2-0.895-2-2s0.895-2 2-2v0z')
          //- .ctnt-nav-items.ctnt-nav-item-7
            svg.ctnt-nav-items-icon.ctnt-nav-item-services.icon.icon-service-solid
              use(xlink:href='#icon-service-solid')
                symbol#icon-service-solid(viewBox='0 0 40 32')
                  path(d='M34 15.5v0.206l4.356-4.356c1.369-1.369 1.369-3.581 0-4.95l-4.881-4.875c-1.369-1.369-3.581-1.369-4.95 0l-2.506 2.506c-0.169-0.019-0.344-0.031-0.519-0.031h-7c-2.319 0-4.225 1.75-4.475 4h-0.025v7.5c0 1.381 1.119 2.5 2.5 2.5s2.5-1.119 2.5-2.5v-4.5c0 0 0-0.006 0-0.006v-0.994h9.5c0 0 0 0 0.006 0h0.494c2.762 0 5 2.238 5 5v0.5zM21 12v3.5c0 2.488-2.012 4.5-4.5 4.5s-4.5-2.012-4.5-4.5v-7.412c-2.244 0.387-4.112 2.019-4.75 4.263l-1.031 3.6-4.575 4.575c-1.369 1.369-1.369 3.581 0 4.95l4.881 4.881c1.369 1.369 3.581 1.369 4.95 0l2.356-2.356c0.056 0 0.113 0.006 0.169 0.006h10c1.656 0 3-1.344 3-3 0-0.35-0.063-0.688-0.169-1h0.169c1.656 0 3-1.344 3-3 0-0.8-0.313-1.525-0.825-2.063 1.606-0.313 2.819-1.725 2.825-3.425v-0.025c-0.006-1.925-1.569-3.487-3.5-3.487 0 0 0 0 0 0h-7.5z')
        section.sect-mid-ctnt-vdos
          section.sect-mid-contentContainer-vdo
            each video in channel.videos
              a(href=`/watch/${video._id}`)
                .content-containers.content-container-1
                  img.sectionHead-thumbNail(src=`/imgs/thumbnails/${video.thumbnail}`)
                  section.section-details
                    h4.section-details-title= video.title
                    hr(width='50px')
                    .sectionHead-views_N_date
                      h5.sectionHead-views
                        span.views= video.views
                        |  Views
                      - const videoTime = new Date(video.time)
                      h5.sectionHead-date= videoTime.toLocaleString('en-uk', {day: 'numeric', month: 'long', year: 'numeric'})
          section.sect-mid-rows.sect-mid-row-3
        section.sect-mid-ch-about
          h1.sect-mid-ch-about-h1 ABOUT
          if channel.about
            h4.sect-mid-ch-about-text= channel.about
          else
            h4.sect-mid-ch-about-text
             i "The Owner has not added any information regarding this channel."
        if wiresData
          section.sect-mid-ch-wire
            h1.ctnt-home-wire-h1 Wire
            section.sect-mid-ctntRecom-wire-separate
              each wire in wiresData
                section.ctnt-home-wire
                  .ctnt-home-wire-header
                    img.ch-wire-header-img(src='/imgs/default-user-photo.jpg')
                    .ctnt-home-wire-header-meta
                      h3.ctnt-home-wire-header-name= channel.name
                      h3.ctnt-home-wire-header-subs= `${channel.subscribers.length} Subscribers`
                    .ctnt-home-wire-header-date_views
                      h3.wire-header-date= wireTime
                      //- h3.wire-header-views 50,423 Views
                  h4.ctnt-home-wire-text= wire.wireText
        section.sect-mid-ctnt-home
          h1.sect-mid-ctnt-home-h1 HOME
          if latestVideo
            a(href=`/watch/${latestVideo._id}`) 
              .featuredVideo
                //- video.featuredVideo-video(width='640', height='360', controls='', poster='/imgs/thumbnails/thumbnail-65a6f249e887d2567074b7e9-1705439848542.png')
                //-   source(src='/video/sample-video.mp4', type='video/mp4')
                img.featuredVideo-video(src="/imgs/thumbnails/sample.jpg", alt="")
                h2.featuredVideo-title= latestVideo.title
          .most-popular
            if videos
              h2.most-popular-h2 MOST POPULAR
              section.sect-mid-ctnt-popular-vdo
                each video in videos
                  a(href=`/watch/${video._id}`) 
                    if video && video.thumbnail
                      .content-containers.content-container-1
                        img.sectionHead-thumbNail(src=`/imgs/thumbnails/${video.thumbnail}`)
                        section.section-details
                          h4.section-details-title= video.title
                          hr(width='50px')
                          .sectionHead-views_N_date
                            h5.sectionHead-views
                              span.views= video.views
                              |  Views
                            h5.sectionHead-date
                              span
                                | 19 
                                span hours
                              |  ago
                    else
                      h1 There are no videos found.
            else if videos === null || undefined
              h2.most-popular-h2
          .ctnt-home-wires
            if wiresData
              h1.ctnt-home-wire-h1 Wire
              section.sect-mid-ctntRecom-wire
                each wire in wiresData
                  section.ctnt-home-wire
                    .ctnt-home-wire-header
                      img.ch-wire-header-img(src='/imgs/default-user-photo.jpg')
                      .ctnt-home-wire-header-meta
                        h3.ctnt-home-wire-header-name= channel.name
                        h3.ctnt-home-wire-header-subs= `${channel.subscribers.length} Subscribers`
                      .ctnt-home-wire-header-date_views
                        h3.wire-header-date= wireTime
                        //- h3.wire-header-views 50,423 Views
                    h4.ctnt-home-wire-text= wire.wireText
            else if wiresData === null || undefined 
              h4.ctnt-home-wire-text
                i "There are no wires related to this channel."
  script(src='https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.2/axios.min.js')
  script(src="/js/subscribe.js")