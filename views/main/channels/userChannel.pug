          .sect-mid-accDtls-h4s
            h4.sect-mid-accDtls-chName= channel.name
            h4.sect-mid-accDtls-subsCount= channel.subscribersCount + ' ' + 'Subscribers'
            input.userId-input(type="hidden", value=`${user._id}`)
          .sect-mid-accDtls-subsBtn
            //- a(href=`/channels/${channel._id}/subscribe`)
            if isItMyChannel
              button.sect-mid-accDtls-subscribe(data-channel-id=channel._id) Analytics
            else 
              button.sect-mid-accDtls-subscribe(data-channel-id=channel._id) Subscribe
            button.sect-mid-accDtls-notification
              img.sect-mid-accDtls-notify-icon.icon.icon-bell-solid(src="https://begenone-images.s3.amazonaws.com/bell-solid.svg", alt="")
        .sect-mid-sorting-list
          .sect-mid-sortings.sect-mid-sorting-1
            img.icon.icon-fire(src="https://begenone-images.s3.amazonaws.com/fire-solid.svg", alt="")
          .sect-mid-sortings.sect-mid-sorting-2
            h3.sect-mid-sort-old OLD
            h3.sect-mid-sort-new NEW
          .sect-mid-sortings.sect-mid-sorting-3
            img.icon.icon-stats-bars(src="https://begenone-images.s3.amazonaws.com/chart-simple-solid.svg", alt="")
          .sect-mid-sortings.sect-mid-sorting-4
            img.icon.icon-ruler-combined-solid(src="https://begenone-images.s3.amazonaws.com/ruler-combined-solid.svg", alt="")
          .sect-mid-sortings.sect-mid-sorting-5
            img.icon.icon-child-solid(src="https://begenone-images.s3.amazonaws.com/child-solid.svg", alt="")
          .sect-mid-sortings.sect-mid-sorting-6
            img.icon.icon-calendar-solid(src="https://begenone-images.s3.amazonaws.com/calendar-solid.svg", alt="")
          .sect-mid-sortings.sect-mid-sorting-search
            img.icon.icon-search(src="https://begenone-images.s3.amazonaws.com/magnifying-glass-solid.svg", alt="")
      section.sect-mid-rows.sect-mid-row-3
        section.sect-mid-ctnt-nav
          .ctnt-nav-items.ctnt-nav-item-1
            svg.ctnt-nav-items-icon.ctnt-nav-item-home.icon.icon-house-solid
              use(xlink:href='#icon-house-solid')
                symbol#icon-house-solid(viewBox='0 0 36 32')
                  path(d='M35.987 15.969c0 1.125-0.938 2.006-2 2.006h-2l0.044 10.012c0 0.169-0.013 0.337-0.031 0.506v1.006c0 1.381-1.119 2.5-2.5 2.5h-1c-0.069 0-0.137 0-0.206-0.006-0.087 0.006-0.175 0.006-0.262 0.006h-3.531c-1.381 0-2.5-1.119-2.5-2.5v-5.5c0-1.106-0.894-2-2-2h-4c-1.106 0-2 0.894-2 2v5.5c0 1.381-1.119 2.5-2.5 2.5h-3.494c-0.094 0-0.188-0.006-0.281-0.012-0.075 0.006-0.15 0.012-0.225 0.012h-1c-1.381 0-2.5-1.119-2.5-2.5v-7c0-0.056 0-0.119 0.006-0.175v-4.35h-2.006c-1.125 0-2-0.875-2-2.006 0-0.563 0.188-1.063 0.625-1.5l16.025-13.969c0.438-0.438 0.938-0.5 1.375-0.5s0.938 0.125 1.313 0.438l15.962 14.031c0.5 0.438 0.75 0.938 0.688 1.5z')
          .ctnt-nav-items.ctnt-nav-item-2
            svg.ctnt-nav-items-icon.ctnt-nav-item-vdoIcon.icon.icon-clapperboard-solid
              use(xlink:href='#icon-clapperboard-solid')
                symbol#icon-clapperboard-solid(viewBox='0 0 32 32')
                  path(d='M28 2h-5.381l-8 8h5.756l7.988-7.981c-0.119-0.013-0.238-0.019-0.363-0.019zM32 10v-4c0-0.944-0.331-1.819-0.875-2.5l-6.5 6.5h7.375zM18.381 2h-5.762l-8 8h5.756l8-8zM4 2c-2.206 0-4 1.794-4 4v4h0.381l8-8h-4.381zM32 12h-32v14c0 2.206 1.794 4 4 4h24c2.206 0 4-1.794 4-4v-14z')
