          //- .ctnt-nav-items.ctnt-nav-item-4
            svg.ctnt-nav-items-icon.ctnt-nav-item-gem.icon.icon-gem-solid
              use(xlink:href='#icon-gem-solid')
                symbol#icon-gem-solid(viewBox='0 0 32 32')
                  path(d='M7.294 2.112c0.281-0.381 0.731-0.613 1.206-0.613h15c0.475 0 0.925 0.225 1.206 0.613l7 9.5c0.425 0.575 0.381 1.369-0.094 1.9l-14.5 16c-0.281 0.313-0.688 0.494-1.113 0.494s-0.825-0.181-1.113-0.494l-14.5-16c-0.481-0.531-0.519-1.325-0.094-1.9l7-9.5zM9.7 4.6c-0.206 0.156-0.262 0.438-0.131 0.656l3.588 5.975-9.2 0.769c-0.256 0.019-0.456 0.238-0.456 0.5s0.2 0.475 0.456 0.5l12 1c0.025 0 0.056 0 0.081 0l12-1c0.256-0.019 0.456-0.238 0.456-0.5s-0.2-0.475-0.456-0.5l-9.194-0.762 3.587-5.975c0.131-0.219 0.075-0.506-0.131-0.656s-0.494-0.125-0.669 0.063l-5.631 6.094-5.631-6.1c-0.175-0.188-0.463-0.213-0.669-0.063z')
          .ctnt-nav-items.ctnt-nav-item-5
            svg.ctnt-nav-items-icon.ctnt-nav-item-grpCht.icon.icon-inbox-solid
              use(xlink:href='#icon-inbox-solid')
                symbol#icon-inbox-solid(viewBox='0 0 32 32')
                  path(d='M7.563 2c-1.838 0-3.438 1.25-3.881 3.031l-3.563 14.244c-0.081 0.319-0.119 0.644-0.119 0.969v5.756c0 2.206 1.794 4 4 4h24c2.206 0 4-1.794 4-4v-5.756c0-0.325-0.038-0.65-0.119-0.969l-3.563-14.244c-0.444-1.781-2.044-3.031-3.881-3.031h-16.875zM7.563 6h16.875l3 12h-3.2c-0.756 0-1.45 0.425-1.788 1.106l-0.894 1.788c-0.337 0.675-1.031 1.106-1.788 1.106h-7.531c-0.756 0-1.45-0.425-1.787-1.106l-0.894-1.788c-0.338-0.675-1.031-1.106-1.787-1.106h-3.206l3-12z')
