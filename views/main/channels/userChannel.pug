extends ../base

block append head
  link(rel="stylesheet", href="/css/userChannel.css")
  link(rel="stylesheet", href="/css/userChannelMediaQueries.css")

block content
  if channel
    section.sect-mid-contentContainer
      section.sect-mid-rows.sect-mid-row-1
        if user && user.channel && user.channel.bannerImage
          img.sect-mid-banner-img(src=`/imgs/users/${channel.user._id}/banner-images/${channel.bannerImage}`, width='100%')
        else
          img.sect-mid-banner-img(src=`https://begenone-images.s3.amazonaws.com/default-banner-image.jpg`, width='100%')
      section.sect-mid-rows.sect-mid-row-2
        section.sect-mid-chDetails
          section.sect-mid-logo
            if user && user.channel && user.channel.displayImage
              img.sect-mid-logo-img(src=`/imgs/users/${channel.user._id}/display-images/${channel.displayImage}`)
            else
              img.sect-mid-logo-img(src=`https://begenone-images.s3.amazonaws.com/default-user-photo.jpg`)
          section.sect-mid-awards
            svg.sect-mid-awards-tick.icon.icon-checkmark2
              use(xlink:href='#icon-checkmark2')
                symbol#icon-checkmark2(viewBox='0 0 32 32')
                  path(d='M12.42 28.678l-12.433-12.238 6.168-6.071 6.265 6.167 13.426-13.214 6.168 6.071-19.594 19.285zM3.372 16.441l9.048 8.905 16.208-15.953-2.782-2.739-13.426 13.214-6.265-6.167-2.782 2.739z')
