extends base

block append head
  link(rel='stylesheet', href='/css/mainVideoCard.css')

block content
  each video in videos
    .content-containers.content-container-1
        section.section-Header
          img.sectionHead-chLogo(src=`/imgs/users/${user.photo}`)
          .sectionHead-dtls
            .sectionHead-chName_N_sub
              h3.sectionHead-chName= video.channel.name
              h5.sectionHead-chSubCnt
                span 49,000
                |  Subscribers
            img.sectionHead-tick(src='/imgs/Middle Nav/Video card/tick-square 8.png')
        img.sectionHead-thumbNail(src='/imgs/Middle Nav/Video card/thumbnail.png')
        section.section-details
          h4.section-details-title= video.title
          hr(width='50px')
          .sectionHead-views_N_date
            h5.sectionHead-views
              span.views= video.views
              |  Views
            h5.sectionHead-date= video.time.toLocaleString('en-uk', {day: 'numeric', month: 'long', year: 'numeric'})